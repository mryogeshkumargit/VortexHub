<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic to ALL addresses for maximum flexibility -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    
    <!-- Specific config for ModelsLab with relaxed security for troubleshooting -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">modelslab.com</domain>
        <domain includeSubdomains="true">api.modelslab.com</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config> 